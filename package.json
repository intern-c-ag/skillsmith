{
  "name": "vibe",
  "version": "0.1.0",
  "description": "One command to set up Claude Code with skills, agents, and MCPs — learned from how you actually code.",
  "type": "module",
  "bin": {
    "vibe": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node18 --clean",
    "dev": "tsup src/cli.ts --format esm --target node18 --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": ["claude", "claude-code", "skills", "ai", "cli"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
